# Homelab secrets — copy to ~/.claude/secrets.env and fill in real values.
# That file persists between Claude Code web sessions.
#
# Home Assistant long-lived access token (generate in HA → Profile → Security)
HOMELAB_HA_TOKEN=your-long-lived-access-token-here

# Proxmox API token (Datacenter → Permissions → API Tokens)
HOMELAB_PROXMOX_USER=root@pam
HOMELAB_PROXMOX_TOKEN_ID=your-token-id
HOMELAB_PROXMOX_TOKEN_SECRET=your-token-secret

# Add other secrets as needed
