# Copy this file to .env and fill in real values.
# Never commit .env to git.

# Telegram Bot Token — get one from @BotFather on Telegram
TELEGRAM_BOT_TOKEN=your-bot-token-here

# Your Telegram Chat ID — send /start to @userinfobot to find yours
TELEGRAM_CHAT_ID=your-chat-id-here

# Database path (default: ./data/commitments.db)
DATABASE_URL=sqlite:///./data/commitments.db

# Reminder check interval in minutes (default: 60)
REMINDER_CHECK_INTERVAL=60

# MQTT broker for Home Assistant integration (optional)
# If set, the app publishes a heartbeat after each reminder check so HA
# can show a dashboard sensor that goes unavailable if the bot stops running.
MQTT_HOST=homeassistant.local
MQTT_PORT=1883
MQTT_USERNAME=your-mqtt-username
MQTT_PASSWORD=your-mqtt-password
